#!/usr/bin/env bash

# THIS WAS WRITTEN BY A CLANKER

set -euo pipefail

PROJECT_DIR="$(realpath "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/..")"
ROOT_LOCK="$PROJECT_DIR/flake.lock"
TEMPLATE_LOCKS=(
    "$PROJECT_DIR/templates/dev/flake.lock"
    "$PROJECT_DIR/templates/dev-cpp/flake.lock"
)

if ! command -v jq >/dev/null 2>&1; then
    echo "[err] jq is required to sync nixpkgs lock entries." >&2
    exit 1
fi

if [[ ! -f "$ROOT_LOCK" ]]; then
    echo "[err] root flake lock not found: $ROOT_LOCK" >&2
    exit 1
fi

extract_root_nixpkgs_node() {
    local lock_path="$1"

    jq -e '
        . as $lock
        | $lock.root as $root_key
        | $lock.nodes[$root_key].inputs.nixpkgs as $nixpkgs_key
        | if ($root_key | type) != "string" then
            error("missing string .root")
          elif ($nixpkgs_key | type) != "string" then
            error("missing string root nixpkgs input")
          elif ($lock.nodes[$nixpkgs_key] // null) == null then
            error("missing selected nixpkgs node")
          else
            $lock.nodes[$nixpkgs_key]
          end
    ' "$lock_path"
}

sync_template_lock() {
    local template_lock="$1"
    local tmp_path=

    if [[ ! -f "$template_lock" ]]; then
        echo "[err] template flake lock not found: $template_lock" >&2
        return 1
    fi

    tmp_path="$(mktemp "${template_lock}.tmp.XXXXXX")"
    jq --argjson nixpkgs_node "$ROOT_NIXPKGS_NODE" '
        . as $lock
        | $lock.root as $root_key
        | $lock.nodes[$root_key].inputs.nixpkgs as $nixpkgs_key
        | if ($root_key | type) != "string" then
            error("missing string .root")
          elif ($nixpkgs_key | type) != "string" then
            error("missing string root nixpkgs input")
          elif ($lock.nodes[$nixpkgs_key] // null) == null then
            error("missing selected nixpkgs node")
          else
            $lock | .nodes[$nixpkgs_key] = $nixpkgs_node
          end
    ' "$template_lock" > "$tmp_path"
    mv "$tmp_path" "$template_lock"

    echo "[info] synced nixpkgs in $template_lock"
}

ROOT_NIXPKGS_NODE="$(extract_root_nixpkgs_node "$ROOT_LOCK")"

for template_lock in "${TEMPLATE_LOCKS[@]}"; do
    sync_template_lock "$template_lock"
done
