#!/usr/bin/env bash

if [[ ! -e "$PWD/flake.nix" ]]; then
    echo "[error] no flake.nix found in '$PWD/flake.nix'" >&2
    exit 1
fi

LOCK_FILE="$PWD/flake.lock"
if [[ ! -f "$LOCK_FILE" ]]; then
    echo "[error] flake.lock missing at '$LOCK_FILE'" >&2
    exit 1
fi

# Format an epoch as YYYY-MM-DD UTC; fall back to '<error_date>' on bad input.
fmt_epoch() {
    local epoch="$1"
    if [[ -z "$epoch" || "$epoch" == "null" || ! "$epoch" =~ ^[0-9]+$ ]]; then
        echo '<error_date>'
        return
    fi
    date -u -d "@$epoch" '+%Y-%m-%d' 2>/dev/null || echo '<error_date>'
}

# Shorten a rev to 7 chars; pass through error sentinels untouched.
short_rev() {
    local rev="$1"
    if [[ -z "$rev" || "$rev" == "null" || "$rev" == "<error_"* ]]; then
        echo "$rev"
        return
    fi
    echo "${rev:0:7}"
}

# === Get nixos nixpkgs rev + date ===
NIXOS_REV='<error_nixos>'
NIXOS_DATE='<error_nixos>'
if command -v "nixos-version" &> /dev/null; then
    NIXOS_JSON=$(nixos-version --json 2>/dev/null)
    if [[ -n "$NIXOS_JSON" ]]; then
        rev=$(jq -r '.nixpkgsRevision // ""' <<< "$NIXOS_JSON")
        if [[ -n "$rev" && "$rev" != "null" ]]; then
            NIXOS_REV="$rev"
        else
            echo "[error] invalid nixos rev: '$rev'" >&2
        fi
        # nixosVersion format: '25.05.20250101.abc1234' -> extract YYYYMMDD
        ver=$(jq -r '.nixosVersion // ""' <<< "$NIXOS_JSON")
        if [[ "$ver" =~ \.([0-9]{4})([0-9]{2})([0-9]{2})\. ]]; then
            NIXOS_DATE="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}"
        else
            echo "[error] cannot parse date from nixosVersion: '$ver'" >&2
        fi
    else
        echo "[error] empty output from 'nixos-version --json'" >&2
    fi
else
    echo "[error] command 'nixos-version' is unavailable." >&2
fi

# === Get current flake nixpkgs input name + rev + lastModified ===
FLAKE_INPUT='<error_flake>'
FLAKE_REV='<error_flake>'
FLAKE_DATE='<error_flake>'
FLAKE_OWNER='<error_flake>'
FLAKE_REPO='<error_flake>'

read -r FLAKE_INPUT FLAKE_REV FLAKE_LM FLAKE_OWNER FLAKE_REPO FLAKE_TYPE < <(jq -r '
    . as $lock
    | if ($lock.root // null) == null then
          "<error_flake: missing .root> <error_flake> <error_flake> <error_flake> <error_flake> <error_flake>"
      else
          $lock.root as $root_key
          | if ($lock.nodes[$root_key] // null) == null then
                "<error_flake: missing .nodes[\($root_key | @json)]> <error_flake> <error_flake> <error_flake> <error_flake> <error_flake>"
            else
                $lock.nodes[$root_key].inputs.nixpkgs as $nixpkgs_key
                | if $nixpkgs_key == null then
                      "<error_flake: missing .nodes[root].inputs.nixpkgs> <error_flake> <error_flake> <error_flake> <error_flake> <error_flake>"
                  elif ($lock.nodes[$nixpkgs_key] // null) == null then
                      "<error_flake: missing .nodes[\($nixpkgs_key | @json)]> <error_flake> <error_flake> <error_flake> <error_flake> <error_flake>"
                  else
                      $lock.nodes[$nixpkgs_key] as $n
                      | [
                          $nixpkgs_key,
                          ($n.locked.rev // "<error_flake>"),
                          ($n.locked.lastModified // "<error_flake>"),
                          ($n.locked.owner // "<error_flake>"),
                          ($n.locked.repo // "<error_flake>"),
                          ($n.locked.type // "<error_flake>")
                      ] | join(" ")
                  end
            end
      end
' "$LOCK_FILE")

if [[ "$FLAKE_REV" == "<error_flake"* ]]; then
    echo "[error] failed to read nixpkgs from flake.lock (input='$FLAKE_INPUT')" >&2
else
    FLAKE_DATE=$(fmt_epoch "$FLAKE_LM")
fi

# === Print summary ===
printf 'nixos:\n'
printf '  rev:  %s\n' "$(short_rev "$NIXOS_REV")"
printf '  date: %s\n' "$NIXOS_DATE"
printf 'flake:\n'
printf '  input: %s\n' "$FLAKE_INPUT"
printf '  rev:   %s\n' "$(short_rev "$FLAKE_REV")"
printf '  date:  %s\n' "$FLAKE_DATE"

printf 'status: '
if [[ "$NIXOS_REV" == '<error_'* || "$FLAKE_REV" == '<error_'* ]]; then
    echo "unknown" >&2
    exit 1
fi
if [[ "$NIXOS_REV" == "$FLAKE_REV" ]]; then
    echo "in sync"
    exit 0
fi
echo "out of sync"

# === Prompt to sync ===
if [[ "$FLAKE_TYPE" != "github" ]]; then
    echo "[error] cannot auto-sync: flake nixpkgs input type is '$FLAKE_TYPE', expected 'github'" >&2
    exit 1
fi

read -rp "apply nixos nixpkgs rev to project flake.lock? [y/*]: " answer
[[ "$answer" != "y" ]] && exit 1

OVERRIDE="github:${FLAKE_OWNER}/${FLAKE_REPO}/${NIXOS_REV}"
echo "[info] running: nix flake lock --override-input '$FLAKE_INPUT' '$OVERRIDE'"
exec nix flake lock --override-input "$FLAKE_INPUT" "$OVERRIDE"
