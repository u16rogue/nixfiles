#!/usr/bin/env bash

# Get nixos
printf "nixos: "
if command -v "nixos-version" &> /dev/null; then
    NIXOS_REV=$(nixos-version --json | jq -r '.nixpkgsRevision')
    if [[ -n "$NIXOS_REV" && "$NIXOS_REV" != "null" ]]; then
        echo "$NIXOS_REV"
    else
        echo "[error] invalid rev: '$NIXOS_REV'" >&2
        NIXOS_REV='<error_nixos>'
    fi
else
    echo "[error] command 'nixos-version' is unavailable."
    NIXOS_REV='<error_nixos>'
fi

# Get current flake
LOCK_FILE="$PWD/flake.lock"
printf "flake: "
if [[ -f "$LOCK_FILE" ]]; then
    FLAKE_REV=$(jq -r '
        . as $lock
        | if ($lock.root // null) == null then
              "<error_flake: missing .root>"
          else
              $lock.root as $root_key
              | if ($lock.nodes[$root_key] // null) == null then
                    "<error_flake: missing .nodes[\($root_key | @json)]>"
                else
                    $lock.nodes[$root_key] as $root_node
                    | if ($root_node.inputs.nixpkgs // null) == null then
                          "<error_flake: missing .nodes[\($root_key | @json)].inputs.nixpkgs>"
                      else
                          $root_node.inputs.nixpkgs as $nixpkgs_key
                          | if ($lock.nodes[$nixpkgs_key] // null) == null then
                                "<error_flake: missing .nodes[\($nixpkgs_key | @json)]>"
                            elif ($lock.nodes[$nixpkgs_key].locked.rev // null) == null then
                                "<error_flake: missing .nodes[\($nixpkgs_key | @json)].locked.rev>"
                            else
                                $lock.nodes[$nixpkgs_key].locked.rev
                            end
                      end
                end
          end
    ' "$LOCK_FILE")
    if [[ -n "$FLAKE_REV" && "$FLAKE_REV" != "null" && "$FLAKE_REV" != "<error_flake:"* ]]; then
        echo "$FLAKE_REV"
    else
        echo "[error] invalid rev: '$FLAKE_REV'" >&2
        FLAKE_REV='<error_flake>'
    fi
else
    echo "[error] flake.lock missing at '$LOCK_FILE'" >&2
    FLAKE_REV='<error_flake>'
fi

printf "status: "
if [[ "$NIXOS_REV" == "$FLAKE_REV" ]]; then
    echo "in sync"
    exit 0
else
    echo "out of sync" >&2
    exit 1
fi
