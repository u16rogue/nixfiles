#!/usr/bin/env bash

# [clanker] rewrite.
# Original user prompt: can you look at the git-cans script and modify it so it detects all the commits that ive made previously and also sign them if they are unsigned but it should cut off at the last signed commit i made. if its not clear what im asking for you should ask.
# Original: `${pkgs.git}/bin/git commit --amend --no-edit -S`

set -euo pipefail

if ! inside_work_tree="$(git rev-parse --is-inside-work-tree 2>/dev/null)"; then
    echo "git-cans: not inside a Git work tree." >&2
    exit 1
fi

if [[ "$inside_work_tree" != "true" ]]; then
    echo "git-cans: not inside a Git work tree." >&2
    exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
    echo "git-cans: refusing to rebase with dirty worktree or index." >&2
    exit 1
fi

if ! author_ident="$(git var GIT_AUTHOR_IDENT 2>/dev/null)"; then
    echo "git-cans: unable to detect current Git author identity." >&2
    exit 1
fi

author_email="${author_ident#*<}"
author_email="${author_email%%>*}"

if [[ -z "$author_email" || "$author_email" == "$author_ident" ]]; then
    echo "git-cans: unable to parse current Git author email." >&2
    exit 1
fi

if ! commit_log="$(git log --format='%H%x09%ae%x09%G?' HEAD 2>/dev/null)"; then
    echo "git-cans: HEAD does not point to a commit." >&2
    exit 1
fi

cutoff=""
unsigned_count=0

while IFS=$'\t' read -r commit author status; do
    if [[ -z "$commit" || "$author" != "$author_email" ]]; then
        continue
    fi

    case "$status" in
        G|U)
            cutoff="$commit"
            break
            ;;
        N)
            unsigned_count=$((unsigned_count + 1))
            ;;
        *)
            echo "git-cans: refusing to rewrite; commit $commit by $author_email has signature status '$status'." >&2
            exit 1
            ;;
    esac
done <<< "$commit_log"

if [[ -z "$cutoff" ]]; then
    echo "git-cans: refusing to rewrite without a signed cutoff commit by $author_email." >&2
    exit 1
fi

cutoff_short="$(git rev-parse --short "$cutoff")"

if [[ "$unsigned_count" -eq 0 ]]; then
    echo "git-cans: no unsigned commits by $author_email newer than signed cutoff $cutoff_short."
    exit 0
fi

while IFS=$'\t' read -r range_commit range_author; do
    if [[ -z "$range_commit" || "$range_author" == "$author_email" ]]; then
        continue
    fi

    range_short="$(git rev-parse --short "$range_commit")"
    echo "git-cans: refusing to rebase; rewrite range $cutoff_short..HEAD contains commit $range_short authored by $range_author." >&2
    echo "git-cans: rebasing would rewrite commits not authored by the current user $author_email." >&2
    exit 1
done < <(git log --format='%H%x09%ae' "$cutoff..HEAD")

if merge_commit="$(git rev-list --merges --max-count=1 "$cutoff..HEAD")" && [[ -n "$merge_commit" ]]; then
    merge_short="$(git rev-parse --short "$merge_commit")"
    echo "git-cans: refusing to rebase; rewrite range $cutoff_short..HEAD contains merge commit $merge_short." >&2
    echo "git-cans: plain rebase would linearize merge history." >&2
    exit 1
fi

echo "git-cans: signing $unsigned_count unsigned commit(s) by $author_email newer than signed cutoff $cutoff_short."

exec_cmd='set -eu; head_email="$(git log -1 --format=%ae HEAD)"; head_sig="$(git log -1 --format="%G?" HEAD)"; if [ "$head_email" = "$GIT_CANS_AUTHOR_EMAIL" ] && [ "$head_sig" = "N" ]; then git commit --amend --no-edit -S; fi'

export GIT_CANS_AUTHOR_EMAIL="$author_email"
git rebase --no-gpg-sign --exec "$exec_cmd" "$cutoff"

echo "git-cans: signed unsigned commits by $author_email newer than $cutoff_short."
