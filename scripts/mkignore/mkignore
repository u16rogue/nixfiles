#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "[error] usage: $0 <output file>" >&2
    exit 1
fi

OUT_FILE=$(realpath "$1")
if [ -f "$OUT_FILE" ]; then
    echo "[error] target $OUT_FILE already exists." >&2
    exit 1
fi

FILE_NAME=$(basename "$1")
TARGET_DIR="$(dirname "$OUT_FILE")"

cat > "$OUT_FILE" <<EOF
**
.*
!$FILE_NAME
EOF

entries=()
while IFS= read -r path; do
    entries+=("$path")
done < <(find "$TARGET_DIR" -mindepth 1 -maxdepth 1 \( ! -path "$OUT_FILE" ! -name ".*" \))

{
    for path in "${entries[@]}"; do
        rel=$(realpath --relative-to="$TARGET_DIR" "$path")
        if [ ! -d "$path" ]; then
            echo "!$rel"
        fi
    done | sort

    for path in "${entries[@]}"; do
        rel=$(realpath --relative-to="$TARGET_DIR" "$path")
        if [ -d "$path" ]; then
            echo "!$rel/"
        fi
    done | sort
} >> "$OUT_FILE"
